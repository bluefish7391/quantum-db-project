{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "ng serve",
      "group": "build",
      "options": { "cwd": "${workspaceFolder}/frontend" }
    },
    {
      "label": "Start Backend (Node)",
      "type": "shell",
      "command": "nodemon --exec npx ts-node index.ts",
      "group": "build",
      "options": { "cwd": "${workspaceFolder}/backend" }
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Frontend", "Start Backend (Node)"]
    }
  ]
}
